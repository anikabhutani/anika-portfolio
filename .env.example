# ── Terminal AI agent ("anika" command) ─────────────────────────────
# Free tier, no credit card — from aistudio.google.com > Get API Key.
GEMINI_API_KEY=

# ── GitHub "Proof of Work" integration ─────────────────────────────
# Personal access token, "public_repo" / read-only scope is enough.
GITHUB_TOKEN=
GITHUB_USERNAME=anikabhutani

# ── Supabase (reading list + contact submissions) ──────────────────
# Project Settings > API in your Supabase dashboard.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server only, never exposed to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ── Contact form email (Resend) ─────────────────────────────────────
RESEND_API_KEY=
CONTACT_TO_EMAIL=abhutani@berkeley.edu
CONTACT_FROM_EMAIL=onboarding@resend.dev
